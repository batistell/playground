{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Rodar Aplicacao (App.java)",
            "request": "launch",
            "mainClass": "playground.App",
            "projectName": "playground"
        },
        {
            "type": "java",
            "name": "Rodar Arquivo Atual",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "Executar Todos os Testes (JUnit)",
            "request": "launch",
            "mainClass": "playground.TestChecklist",
            "projectName": "playground",
            "classPaths": [
                "$Runtime",
                "$Test"
            ],
            "vmArgs": [
                "-ea"
            ]
        }
    ]
}